<Page x:Class="pract12_trpo.Pages.CourseForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract12_trpo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CourseForm">

    <StackPanel>
        <Button Width="100" Click="go_back" HorizontalAlignment="Left">Назад</Button>
        <TextBlock>Название курса</TextBlock>
        <TextBox Text="{Binding Title}"></TextBox>
        <Button Click="save">Сохранить</Button>
    </StackPanel>
</Page>
