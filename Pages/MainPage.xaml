<Page x:Class="pract12_trpo.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract12_trpo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">
    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal">
            <Button Click="go_form">Добавить</Button>
            <Button Click="remove">Удалить</Button>
            <Button Click="go_group">Группы</Button>
            <Button Click="go_courses">Курсы</Button>
            <Button Click="go_sign">Запиать на курс</Button>
        </StackPanel>
        <ListView Grid.Row="1"
                  ItemsSource="{Binding service.Students}"
                  MouseDoubleClick="Edit"
                  SelectedItem="{Binding student}"
                  MouseDown="UpdateCourseList">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Id}"></TextBlock>
                            <TextBlock Text="{Binding FirstName}"></TextBlock>
                            <TextBlock Text="{Binding MiddleName}"></TextBlock>
                            <TextBlock Text="{Binding LastName}"></TextBlock>
                            <TextBlock Text="{Binding Birthday, StringFormat={}{0:dd.MM.yyyy}}"></TextBlock>
                            <TextBlock>Паспорт</TextBlock>
                            <TextBlock>
                                <Run Text="Серия: "/>
                                <Run Text="{Binding Passport.Series}"/>
                                <Run Text="Номер: "/>
                                <Run Text="{Binding Passport.Number}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Группа: "/>
                                <Run Text="{Binding Group.Title}"/>
                            </TextBlock>
                        </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ListView Grid.Row="1"
                  Grid.Column="1"
                  ItemsSource="{Binding student.CourseStudents}"> 
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel>
                            <TextBlock>Курс: </TextBlock>
                            <TextBlock Text="{Binding Course.Title}"></TextBlock>
                            <TextBlock>Дата начала: </TextBlock>
                            <TextBlock Text="{Binding StartDate}"></TextBlock>
                            <TextBlock>Дата окончания: </TextBlock>
                            <TextBlock Text="{Binding EndDate}"></TextBlock>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
