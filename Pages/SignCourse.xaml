<Page x:Class="pract12_trpo.Pages.SignCourse"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract12_trpo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignCourse">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Button HorizontalAlignment="Left" Click="go_back">Назад</Button>
        <StackPanel Grid.Column="0"
                    Grid.Row="1">
            <Label FontSize="20">Информация о студенте</Label>
            <TextBlock Text="{Binding courseStudent.Student.FirstName}"/>
            <TextBlock Text="{Binding courseStudent.Student.MiddleName}"/>
            <TextBlock Text="{Binding courseStudent.Student.LastName}"/>
            <TextBlock Text="{Binding courseStudent.Student.Group.Title}"/>
            <Label>Дата начала курса</Label>
            <DatePicker x:Name="startDate"></DatePicker>
            <Label>Дата Завершения курса</Label>
            <DatePicker x:Name="endDate"></DatePicker>
            <Button Click="sign">Записать на курс</Button>
        </StackPanel>
        <ListView Grid.Column="1"
                  Grid.Row="1"
                  ItemsSource="{Binding service.Courses}"
                  SelectedItem="{Binding courseStudent.Course}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}"></TextBlock>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
