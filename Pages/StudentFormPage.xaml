<Page x:Class="pract12_trpo.Pages.StudentFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract12_trpo.Pages"
      xmlns:services="clr-namespace:pract12_trpo.DataBase.Service"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="StudentFormPage">
    <Page.Resources>
        <services:GroupsService x:Key="gService"/>
    </Page.Resources>
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="250">
            <StackPanel>
                <Label>Группа</Label>
                <ComboBox ItemsSource="{Binding Source={StaticResource gService}, Path=Groups}"
                          DisplayMemberPath="Title"
                          SelectedItem="{Binding Group}"/>
            </StackPanel>
            <StackPanel>
                <Label>Фамилия</Label>
                <TextBox Text="{Binding LastName}"></TextBox>
            </StackPanel>
            <StackPanel>
                <Label>Имя</Label>
                <TextBox Text="{Binding FirstName}"></TextBox>
            </StackPanel>
            <StackPanel>
                <Label>Отчество</Label>
                <TextBox Text="{Binding MiddleName}"></TextBox>
            </StackPanel>
            <StackPanel>
                <Label>Дата рождения</Label>
                <DatePicker SelectedDate="{Binding Birthday}"/>
            </StackPanel>
            <StackPanel>
                <Label>Серия паспорта</Label>
                <TextBox Text="{Binding Passport.Number}"/>
            </StackPanel>
            <StackPanel>
                <Label>Номер паспорта</Label>
                <TextBox Text="{Binding Passport.Series}"/>
            </StackPanel>
            <StackPanel>
                <Button Click="save">Сохранить в БД</Button>
                <Button Click="back">Назад</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
